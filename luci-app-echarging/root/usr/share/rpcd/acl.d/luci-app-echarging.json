{
	"luci-app-echarging": {
		"description": "Grant access to echarging configuration",
		"read": {
			"uci": ["echarging"],
			"file": {
				"/usr/bin/echarging": ["exec"],
				"/usr/bin/echarging-uci2json": ["exec"],
				"/etc/init.d/echarging": ["exec"]
			}
		},
		"write": {
			"uci": ["echarging"]
		}
	}
}
