#!/bin/sh

# UCI -> JSON converter for 5echarging
# Reads /etc/config/5echarging and writes /var/etc/5echarging.json

. /lib/functions.sh

CONFIG_FILE="/var/etc/5echarging.json"
mkdir -p /var/etc

config_load 5echarging

# --- Read global ---
config_get LOW_ENERGY_THRESHOLD global low_energy_threshold ""
config_get THRESHOLD_LEGACY global threshold 15
config_get DB_PATH global db_path /etc/5echarging/5echarging.bbolt
config_get DEPLETION_ALERT_DAYS global depletion_alert_days 0
config_get MAX_RECORDS_PER_ROOM global max_records_per_room 500
mkdir -p "$(dirname "$DB_PATH")"

[ -n "$LOW_ENERGY_THRESHOLD" ] || LOW_ENERGY_THRESHOLD="$THRESHOLD_LEGACY"

# --- Read schedule ---
config_get INTERVAL schedule interval_minutes 60

CHECK_HOURS=""
append_check_hour() {
	if [ -z "$CHECK_HOURS" ]; then
		CHECK_HOURS="$1"
	else
		CHECK_HOURS="$CHECK_HOURS,$1"
	fi
}
config_list_foreach schedule check_hours append_check_hour

# --- Read prediction ---
config_get SAMPLE_COUNT prediction sample_count 10
config_get CUSTOM_DAILY_CONSUMPTION prediction custom_daily_consumption ""
config_get CUSTOM_RATE_LEGACY prediction custom_daily_rate 0

[ -n "$CUSTOM_DAILY_CONSUMPTION" ] || CUSTOM_DAILY_CONSUMPTION="$CUSTOM_RATE_LEGACY"

# --- Read email ---
config_get EMAIL_ENABLED email enabled 0
config_get SMTP_HOST email smtp_host ""
config_get SMTP_PORT email smtp_port 587
config_get EMAIL_USER email username ""
config_get EMAIL_PASS email password ""
config_get EMAIL_FROM email from_addr ""

# --- Read rooms ---
ROOMS=""
add_room() {
	local section="$1" recipients_json
	local building room label
	config_get building "$section" building ""
	config_get room "$section" room ""
	config_get label "$section" label ""
	[ -z "$building" ] || [ -z "$room" ] && return

	recipients_json=""
	append_room_recipient() {
		[ -z "$1" ] && return
		if [ -z "$recipients_json" ]; then
			recipients_json="\"$1\""
		else
			recipients_json="$recipients_json,\"$1\""
		fi
	}
	config_list_foreach "$section" recipients append_room_recipient

	local entry="{\"building\":\"$building\",\"room\":\"$room\",\"label\":\"$label\",\"recipients\":[${recipients_json}]}"
	if [ -z "$ROOMS" ]; then
		ROOMS="$entry"
	else
		ROOMS="$ROOMS,$entry"
	fi
}
config_foreach add_room room

# --- Build check_hours array ---
CH_ARRAY=""
if [ -n "$CHECK_HOURS" ]; then
	CH_ARRAY="$CHECK_HOURS"
fi

# --- Convert booleans ---
[ "$EMAIL_ENABLED" = "1" ] && EMAIL_ENABLED_JSON="true" || EMAIL_ENABLED_JSON="false"

# --- Write JSON ---
cat > "$CONFIG_FILE" <<EOF
{
  "rooms": [${ROOMS}],
  "schedule": {
    "interval_minutes": ${INTERVAL},
    "check_hours": [${CH_ARRAY}]
  },
  "low_energy_threshold": ${LOW_ENERGY_THRESHOLD},
  "depletion_alert_days": ${DEPLETION_ALERT_DAYS},
  "max_records_per_room": ${MAX_RECORDS_PER_ROOM},
  "prediction": {
    "sample_count": ${SAMPLE_COUNT},
    "custom_daily_consumption": ${CUSTOM_DAILY_CONSUMPTION}
  },
  "email": {
    "enabled": ${EMAIL_ENABLED_JSON},
    "smtp_host": "${SMTP_HOST}",
    "smtp_port": ${SMTP_PORT},
    "username": "${EMAIL_USER}",
    "password": "${EMAIL_PASS}",
    "from": "${EMAIL_FROM}"
  },
  "db_path": "${DB_PATH}"
}
EOF
